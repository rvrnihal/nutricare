# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# AI Mode Configuration
# Options: groq (primary), local (trained model), fallback (database)
AI_MODE=groq

# Server Configuration
PORT=5000
NODE_ENV=development

# Local AI URL (for trained models)
LOCAL_AI_URL=http://127.0.0.1:8000/generate

# Timeout settings (in seconds)
API_TIMEOUT=30
GROQ_TIMEOUT=15

# Fallback behavior (true = use fallback if all others fail)
USE_FALLBACK=true

# Hugging Face Token (optional, for local model inference)
HF_TOKEN=

# CORS settings
CORS_ORIGIN=*
